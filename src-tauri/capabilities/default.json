{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for the main window",
  "windows": ["main", "spotify-auth"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "core:webview:allow-create-webview-window",
    "dialog:default",
    "opener:default",
    "stt:default",
    "llm:default",
    "llm:allow-complete",
    "llm:allow-ensure-model",
    "llm:allow-is-ready",
    "updater:default"
  ]
}
