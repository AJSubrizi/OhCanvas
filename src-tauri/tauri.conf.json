{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OhCanvas",
  "version": "0.1.0",
  "identifier": "dev.ohcanvas.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm vite",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "OhCanvas",
        "width": 1440,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "dragDropEnabled": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "externalBin": [
      "binaries/ohcanvas-sidecar"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/AJSubrizi/OhCanvas/releases/latest/download/latest-release.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEIwQUJBODE0QjRDNTJDRTYKUldUbUxNVzBGS2lyc0F4eUdPbmh0TFpzRmVNSWY5WWE4TTZST2xiWG83Z0lRN2Q0L2dLVlp5cXAK"
    }
  }
}
