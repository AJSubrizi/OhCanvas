{
  "name": "sidecar",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "test": "tsx --test src/**/*.test.ts",
    "build": "bun build --compile --target=bun-${BUILD_TARGET:-$(uname -m | sed 's/x86_64/x64; s/aarch64/arm64/')}-${BUILD_PLATFORM:-$(uname -s | tr '[:upper:]' '[:lower:]')} --outfile ../src-tauri/binaries/ohcanvas-sidecar${BIN_SUFFIX:-} src/index.ts"
  },
  "dependencies": {
    "@lydell/node-pty": "1.2.0-beta.12",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/ws": "^8.5.13",
    "bun-types": "^1.3.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
